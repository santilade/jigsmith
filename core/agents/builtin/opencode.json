{
  "id": "opencode",
  "label": "opencode",
  "tag": "oc",
  "cli": "opencode",
  "run": {
    "headless": ["opencode", "run", "--dangerously-skip-permissions", "{prompt}"],
    "headless_stream": ["opencode", "run", "--dangerously-skip-permissions", "--format", "json", "{prompt}"],
    "stream_format": "opencode-json",
    "interactive": ["opencode"]
  },
  "inspect": {
    "history": {"glob": "~/.local/share/opencode/storage/**/*.json", "format": "opencode-store"},
    "settings": {
      "config": "~/.config/opencode/opencode.json",
      "mcp": "~/.config/opencode/opencode.json",
      "agents": "~/.config/opencode/agent",
      "memory": "~/.config/opencode/AGENTS.md"
    }
  }
}
